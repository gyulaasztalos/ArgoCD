  "timepicker": {
    "refresh_intervals": ["1m", "5m", "15m", "30m", "1h"]
  },
  "timezone": "Europe/Budapest",
  "title": "Refrigeration Temperatures (HACCP)",
  "uid": "fridge-haccp",
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "Fridges (limit 5 °C)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "title": "Fridge — Current",
      "type": "stat",
      "datasource": { "type": "influxdb", "uid": "influxdb" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": ".*_temperature_3.*" },
            "properties": [ { "id": "displayName", "value": "LG Fridge" } ] },
          { "matcher": { "id": "byRegexp", "options": ".*_temperature_4.*" },
            "properties": [ { "id": "displayName", "value": "Electrolux Fridge" } ] }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": true },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "from(bucket: \"homeassistant\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"°C\" and r._field == \"value\")\n  |> filter(fn: (r) => r.entity_id =~ /0x58e6c5fffe0f58b0_temperature_[34]/)\n  |> last()",
          "refId": "A"
        }
      ]
    },
