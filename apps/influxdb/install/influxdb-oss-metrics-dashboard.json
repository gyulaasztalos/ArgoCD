{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["influxdb", "prometheus"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "Europe/Budapest",
  "title": "InfluxDB 2.x OSS (/metrics via Prometheus)",
  "uid": "influxdb-oss-metrics",
  "panels": [
    {
      "id": 100, "type": "row", "title": "Overview",
      "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1, "title": "Up", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(up{job=\"influxdb\"})", "refId": "A" } ]
    },
    {
      "id": 2, "title": "Go version", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 1 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^version$/", "values": false }, "colorMode": "none", "graphMode": "none", "textMode": "value" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "go_info{job=\"influxdb\"}", "format": "table", "instant": true, "refId": "A" } ]
    },
    {
      "id": 3, "title": "Goroutines", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "none", "graphMode": "area", "textMode": "value" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "go_goroutines{job=\"influxdb\"}", "refId": "A" } ]
    },
    {
      "id": 4, "title": "Heap in use", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "none", "graphMode": "area", "textMode": "value" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "go_memstats_heap_inuse_bytes{job=\"influxdb\"}", "refId": "A" } ]
    },
    {
      "id": 5, "title": "OS threads", "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "none", "graphMode": "none", "textMode": "value" },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "go_threads{job=\"influxdb\"}", "refId": "A" } ]
    },
    {
      "id": 200, "type": "row", "title": "HTTP API",
      "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 10, "title": "Request rate by status", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15, "showPoints": "never", "stacking": { "mode": "normal" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (status) (rate(http_api_request_duration_seconds_count{job=\"influxdb\"}[5m]))", "legendFormat": "{{status}}", "refId": "A" } ]
    },
    {
      "id": 11, "title": "Request rate by path (top 10)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "topk(10, sum by (path) (rate(http_api_request_duration_seconds_count{job=\"influxdb\"}[5m])))", "legendFormat": "{{path}}", "refId": "A" } ]
    },
    {
      "id": 12, "title": "Request latency (p50 / p90 / p99)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(http_api_request_duration_seconds_bucket{job=\"influxdb\"}[5m])))", "legendFormat": "p50", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.90, sum by (le) (rate(http_api_request_duration_seconds_bucket{job=\"influxdb\"}[5m])))", "legendFormat": "p90", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(http_api_request_duration_seconds_bucket{job=\"influxdb\"}[5m])))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "id": 13, "title": "Error ratio (4XX / 5XX)", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 15, "showPoints": "never" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.05 } ] }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_api_request_duration_seconds_count{job=\"influxdb\", status=\"4XX\"}[5m])) / clamp_min(sum(rate(http_api_request_duration_seconds_count{job=\"influxdb\"}[5m])), 1)", "legendFormat": "4XX", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_api_request_duration_seconds_count{job=\"influxdb\", status=\"5XX\"}[5m])) / clamp_min(sum(rate(http_api_request_duration_seconds_count{job=\"influxdb\"}[5m])), 1)", "legendFormat": "5XX", "refId": "B" }
      ]
    },
    {
      "id": 300, "type": "row", "title": "Go runtime & storage",
      "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "id": 20, "title": "Memory", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "go_memstats_heap_alloc_bytes{job=\"influxdb\"}", "legendFormat": "heap alloc (in use)", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "go_memstats_heap_sys_bytes{job=\"influxdb\"}", "legendFormat": "heap sys (reserved)", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "go_memstats_sys_bytes{job=\"influxdb\"}", "legendFormat": "total sys", "refId": "C" }
      ]
    },
    {
      "id": 21, "title": "GC pause (p75 / max) & rate", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0, "showPoints": "never" } }, "overrides": [ { "matcher": { "id": "byName", "options": "GC runs/s" }, "properties": [ { "id": "unit", "value": "ops" }, { "id": "custom.axisPlacement", "value": "right" } ] } ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "go_gc_duration_seconds{job=\"influxdb\", quantile=\"0.75\"}", "legendFormat": "pause p75", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "go_gc_duration_seconds{job=\"influxdb\", quantile=\"1\"}", "legendFormat": "pause max", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(go_gc_duration_seconds_count{job=\"influxdb\"}[5m])", "legendFormat": "GC runs/s", "refId": "C" }
      ]
    },
    {
      "id": 22, "title": "BoltDB (metadata store) ops/s", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(boltdb_reads_total{job=\"influxdb\"}[5m])", "legendFormat": "reads/s", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(boltdb_writes_total{job=\"influxdb\"}[5m])", "legendFormat": "writes/s", "refId": "B" }
      ]
    },
    {
      "id": 23, "title": "Allocation rate", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(go_memstats_alloc_bytes_total{job=\"influxdb\"}[5m])", "legendFormat": "bytes allocated/s", "refId": "A" }
      ]
    }
  ]
}
