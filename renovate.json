{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automergeSchedule": [
    "after 5am every weekday",
    "before 4pm every weekday",
    "every weekend"
  ],
  "timezone": "Europe/Budapest",
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest"
      ],
      "automerge": true
    },
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "automerge": true
    },
    {
      "description": "Causes the bot to create a PR (and thus, an email notification), whenever there is a new Renovate version",
      "matchFileNames": [
        "renovate-update-notification/Dockerfile"
      ],
      "automerge": true
    }
  ],
  "platformAutomerge": true,
  "argocd": {
    "managerFilePatterns": [
      "/application\\.yaml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/values\\.yaml$/"
    ]
  },
  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update versions in Ansible vars with renovate comments",
      "managerFilePatterns": [
        "/resources/my-cluster/group_vars/all\\.yml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>.+?) packageName=(?<packageName>.+?)(?:\\s+versioning=(?<versioning>[a-z-]+?))?\\s*\\n.+?:\\s*(?<currentValue>.+?)\\s*$"
      ]
    },
    {
      "customType": "regex",
      "description": "Update a version pinned in a shell variable inside an app values.yaml (e.g. transmission's initContainer that downloads the Flood web UI from a GitHub release), annotated with a renovate comment. The datasource is taken FROM the comment (github-releases, etc.).",
      "managerFilePatterns": [
        "/apps/.+/values\\.yaml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-z-]+) depName=(?<depName>\\S+?)(?:\\s+versioning=(?<versioning>[a-z-]+))?\\s*\\n\\s*[A-Za-z_][A-Za-z0-9_]*=[\"']?(?<currentValue>[^\"'\\s]+)[\"']?"
      ],
      "datasourceTemplate": "{{{datasource}}}"
    }
  ]
}
